PIXEL_BYTES = N_PIXELS * 2                  # 1536 bytes
FRAME_SIZE  = HEADER_SIZE + PIXEL_BYTES + 2 # 1562 bytes


# ══════════════════════════════════════════════
#  Rainbow colour mapping  (7 colour stops)
#  Maps 0.0–1.0 → (R, G, B) 0–255
# ══════════════════════════════════════════════
# Colour stops: violet → blue → cyan → green → yellow → orange → red
_RAINBOW = [
    (0.00, (148,   0, 211)),   # violet
    (0.17, (  0,   0, 255)),   # blue
    (0.33, (  0, 255, 255)),   # cyan
    (0.50, (  0, 255,   0)),   # green
    (0.67, (255, 255,   0)),   # yellow
    (0.83, (255, 165,   0)),   # orange
    (1.00, (255,   0,   0)),   # red
]

def rainbow_rgb(t):
    """t in [0.0, 1.0] → (r, g, b) tuple 0-255."""
    t = max(0.0, min(1.0, t))
    for i in range(len(_RAINBOW) - 1):
        t0, c0 = _RAINBOW[i]
        t1, c1 = _RAINBOW[i + 1]
        if t0 <= t <= t1:
            f = (t - t0) / (t1 - t0)
            return (
                int(c0[0] + f * (c1[0] - c0[0])),
                int(c0[1] + f * (c1[1] - c0[1])),
                int(c0[2] + f * (c1[2] - c0[2])),
            )
    return _RAINBOW[-1][1]

def rainbow_gray(t):
    """Convert rainbow RGB → 8-bit grey (for monochrome displays)."""
    r, g, b = rainbow_rgb(t)
    return (r * 299 + g * 587 + b * 114) // 1000


