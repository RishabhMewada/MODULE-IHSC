def load_saved_mode():
    try:
        with open(CONFIG_FILE, "r") as f:
            cfg = json.load(f)
        m = int(cfg.get("mode", -1))
        if m in (MODE_USB, MODE_I2C, MODE_BOTH):
            print(f"[CFG] Loaded saved mode: {MODE_NAMES[m]}")
            return m
    except Exception:
        pass
    return None


def save_mode_to_flash(mode):
    try:
        with open(CONFIG_FILE, "w") as f:
            json.dump({"mode": mode}, f)
        print(f"[CFG] Mode saved: {MODE_NAMES[mode]}")
    except Exception as e:
        print(f"[CFG] Save failed: {e}")


